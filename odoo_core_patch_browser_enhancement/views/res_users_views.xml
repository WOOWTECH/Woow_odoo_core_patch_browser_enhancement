<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_users_form_oauth_email" model="ir.ui.view">
        <field name="name">res.users.form.oauth.email</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="auth_oauth.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='oauth_uid']" position="before">
                <field name="oauth_email" string="OAuth User Email"/>
            </xpath>
        </field>
    </record>
</odoo>
